# Copy to .env and fill values
SUPABASE_URL=https://your-project-ref.supabase.co
# Prefer service-role key on server; keep secret and never expose in frontend code.
SUPABASE_KEY=your-server-key
# Optional: set a storage bucket name to store uploads in Supabase Storage.
SUPABASE_BUCKET=profilepicture
# If using service role, put it here and remove SUPABASE_KEY above:
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key